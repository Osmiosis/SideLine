*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/

# Model weights (large binary files)
*.pt
*.pth
*.onnx
*.engine

# Video files (too large for git)
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Data folders (track only .gitkeep markers)
clips/*
datasets/*
outputs/*
runs/*
!clips/.gitkeep
!datasets/.gitkeep
!outputs/.gitkeep
!runs/.gitkeep


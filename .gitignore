# Python
venv/
.venv/
__pycache__/
*.pyc

# Large binaries
*.zip
*.pt

# Data & model artifacts (large). Ignore outputs/ wholesale, then re-include only the
# small curated artifacts (JSON / MD / PNG). Heavy video (*.mp4) stays ignored everywhere.
outputs/

# deliverables: curated package (no raw video)
!outputs/deliverables/
!outputs/deliverables/**

# Day 27: involvement stats + player-highlight manifests/reports (small JSON/PNG/MD)
!outputs/involvement/
!outputs/involvement/**
!outputs/player_highlights/
!outputs/player_highlights/**

# ...but never the heavy stuff: all video, and the bulky per-clip / reel dirs
*.mp4
outputs/player_highlights/**/clips/**
outputs/player_highlights/**/reels/**
